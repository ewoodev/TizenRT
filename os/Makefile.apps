.PHONY: all common_prepare app_all common_finalize

all: common_prepare app_all common_finalize

common_prepare:
	$(MAKE) -f Makefile.os pass1deps

app_all:
	$(MAKE) -f Makefile.unix pass1

common_finalize:
	$(MAKE) -f Makefile.os post_common
